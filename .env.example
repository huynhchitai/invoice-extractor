# ─────────────────────────────────────────────────────────────
# Invoice Extractor — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# ── Google Cloud / Vertex AI ────────────────────────────────
# GCP project ID (required)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# GCP region for Vertex AI (optional, default: us-central1)
GOOGLE_CLOUD_REGION=us-central1

# Option 1 – path to a service-account JSON key file (best for local dev)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-key.json

# Option 2 – full JSON content of the service account, single-line (best for Vercel)
# Generate with: cat gcp-key.json | jq -c '.'
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ── Upstash Redis (rate limiting) ───────────────────────────
# Leave both empty to disable rate limiting (graceful no-op).
# Create a Redis database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
